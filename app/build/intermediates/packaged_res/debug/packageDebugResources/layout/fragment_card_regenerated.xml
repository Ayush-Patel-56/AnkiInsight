<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/color_primary" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Card Regenerated"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/review_ai_suggestion"
                    android:textSize="13sp"
                    android:textColor="@color/color_text_secondary" />
            </LinearLayout>
            <ImageButton
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_more_vert"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/color_text_secondary" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ai_has_rewritten"
            android:textColor="@color/color_text_secondary"
            android:layout_marginBottom="20dp" />

        <!-- ORIGINAL CARD label -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_warning"
                app:tint="@color/color_error"
                android:layout_marginEnd="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/original_card"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textColor="@color/color_error" />
        </LinearLayout>

        <!-- Original card (red left border) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/color_error"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <!-- Red left border -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/color_error" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/question"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:textColor="@color/color_text_secondary"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/tvOriginalQuestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_primary"
                        android:layout_marginBottom="12dp" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/color_divider"
                        android:layout_marginBottom="12dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/answer"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:textColor="@color/color_text_secondary"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/tvOriginalAnswer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/color_text_primary"
                        android:layout_marginBottom="12dp" />
                    <!-- Failed badge chip -->
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Failed 5x • Last failed today"
                        app:chipBackgroundColor="@color/color_surface_variant"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="12sp"
                        style="@style/Widget.Material3.Chip.Assist" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI REGENERATED separator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_down"
                app:tint="@color/color_primary"
                android:layout_marginEnd="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_regenerated"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textColor="@color/color_primary" />
        </LinearLayout>

        <!-- NEW CARD label -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/new_card"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textColor="@color/color_primary" />
        </LinearLayout>

        <!-- Regenerated card (teal left border) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <!-- Teal left border -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/color_primary" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/question"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:textColor="@color/color_text_secondary"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/tvRegenQuestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_primary"
                        android:layout_marginBottom="12dp" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/color_divider"
                        android:layout_marginBottom="12dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/answer"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:textColor="@color/color_text_secondary"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/tvRegenAnswer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/color_text_primary"
                        android:layout_marginBottom="12dp" />
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rewritten_with_analogy"
                        app:chipBackgroundColor="@color/color_primary_container"
                        android:textColor="@color/color_primary"
                        android:textSize="12sp"
                        style="@style/Widget.Material3.Chip.Assist" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccept"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/accept_save"
            android:backgroundTint="@color/color_primary"
            android:layout_marginBottom="10dp"
            android:padding="14dp"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reject_try_again"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/color_text_secondary"
            android:textColor="@color/color_text_primary"
            android:padding="14dp"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>
